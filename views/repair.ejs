<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phone Repair - <%= config.business.name %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/"><%= config.business.name %></a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/repair" class="active">Repair</a></li>
        <li><a href="/sales">Phones</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="phone-header">
        <a href="tel:<%= config.contact.phone %>"><i class="fas fa-phone"></i> <%= config.contact.phone_display %></a>
      </div>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Phone Repair Services</h1>
      <p>Professional repairs for all major brands and models</p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="services-section">
    <div class="container">
      <div class="services-grid">
        <% services.forEach(service => { %>
          <div class="service-card">
            <div class="service-icon">
              <i class="<%= service.icon %>"></i>
            </div>
            <h3><%= service.name %></h3>
            <p><%= service.description %></p>
            <div class="service-features">
              <% service.features.forEach(feature => { %>
                <span><i class="fas fa-check"></i> <%= feature %></span>
              <% }); %>
            </div>
            <a href="/contact" class="service-btn">Inquire Now</a>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Brands Section -->
  <section class="brands-section">
    <div class="container">
      <h2>Brands We Repair</h2>
      <div class="brands-grid">
        <% config.brands.forEach(brand => { %>
          <div class="brand-item"><%= brand %></div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="why-us">
    <div class="container">
      <h2>Why Choose <%= config.business.name %>?</h2>
      <div class="features-grid">
        <% config.features.forEach(feature => { %>
          <div class="feature">
            <i class="fas fa-check-circle"></i>
            <span><%= feature %></span>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Need a repair?</h2>
      <p>Visit our shop or call us for quick assistance</p>
      <div class="cta-buttons">
        <a href="tel:<%= config.contact.phone %>" class="btn btn-primary">
          <i class="fas fa-phone"></i> Call Now
        </a>
        <a href="<%= config.social.whatsapp %>" class="btn btn-success">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3><%= config.business.name %></h3>
          <p><%= config.business.description %></p>
        </div>
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/repair">Repair</a></li>
            <li><a href="/sales">Phones</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Contact</h4>
          <p><i class="fas fa-phone"></i> <a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></p>
          <p><i class="fas fa-map-marker"></i> <%= config.contact.address %></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.business.name %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>