<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phones for Sale - <%= config.business.name %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/"><%= config.business.name %></a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/repair">Repair</a></li>
        <li><a href="/sales" class="active">Phones</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="phone-header">
        <a href="tel:<%= config.contact.phone %>"><i class="fas fa-phone"></i> <%= config.contact.phone_display %></a>
      </div>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Phones for Sale</h1>
      <p>Quality new and refurbished phones with warranty</p>
    </div>
  </section>

  <!-- Phones Grid -->
  <section class="phones-section">
    <div class="container">
      <% if (phones.length === 0) { %>
        <div class="no-results">
          <i class="fas fa-search"></i>
          <h3>No phones found</h3>
        </div>
      <% } else { %>
        <div class="phones-grid">
          <% phones.forEach(phone => { %>
            <div class="phone-card">
              <div class="phone-image">
                <img src="<%= phone.image %>" alt="<%= phone.name %>" onerror="this.src='<%= config.images.default_phone %>'">
                <span class="condition-badge <%= phone.condition.toLowerCase() %>"><%= phone.condition %></span>
              </div>
              <div class="phone-info">
                <h3><%= phone.name %></h3>
                <div class="phone-specs">
                  <span><i class="fas fa-microchip"></i> <%= phone.storage %></span>
                  <span><i class="fas fa-memory"></i> <%= phone.ram %> RAM</span>
                  <span><i class="fas fa-palette"></i> <%= phone.color %></span>
                </div>
                <div class="phone-price"><%= phone.price_formatted %></div>
                <a href="/phone/<%= phone.id %>" class="btn btn-primary btn-block">View Details</a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3><%= config.business.name %></h3>
          <p><%= config.business.description %></p>
        </div>
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/repair">Repair</a></li>
            <li><a href="/sales">Phones</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Contact</h4>
          <p><i class="fas fa-phone"></i> <a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></p>
          <p><i class="fas fa-map-marker"></i> <%= config.contact.address %></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.business.name %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
