<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us - <%= config.business.name %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/"><%= config.business.name %></a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/repair">Repair</a></li>
        <li><a href="/sales">Phones</a></li>
        <li><a href="/contact" class="active">Contact</a></li>
      </ul>
      <div class="phone-header">
        <a href="tel:<%= config.contact.phone %>"><i class="fas fa-phone"></i> <%= config.contact.phone_display %></a>
      </div>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Get in touch with us for any inquiries</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info">
          <h2>Visit Our Shop</h2>
          
          <div class="info-item">
            <i class="fas fa-map-marker-alt"></i>
            <div>
              <h3>Address</h3>
              <p><%= config.contact.address %></p>
            </div>
          </div>

          <div class="info-item">
            <i class="fas fa-phone"></i>
            <div>
              <h3>Call Us</h3>
              <p><a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></p>
            </div>
          </div>

          <div class="info-item">
            <i class="fas fa-envelope"></i>
            <div>
              <h3>Email</h3>
              <p><a href="mailto:<%= config.contact.email %>"><%= config.contact.email %></a></p>
            </div>
          </div>

          <div class="info-item">
            <i class="fas fa-clock"></i>
            <div>
              <h3>Working Hours</h3>
              <p>Mon-Fri: <%= config.hours.monday_friday %></p>
              <p>Sat: <%= config.hours.saturday %></p>
              <p>Sun: <%= config.hours.sunday %></p>
            </div>
          </div>

          <div class="social-links">
            <a href="<%= config.social.facebook %>" target="_blank"><i class="fab fa-facebook"></i></a>
            <a href="<%= config.social.instagram %>" target="_blank"><i class="fab fa-instagram"></i></a>
            <a href="<%= config.social.twitter %>" target="_blank"><i class="fab fa-twitter"></i></a>
            <a href="<%= config.social.whatsapp %>" target="_blank"><i class="fab fa-whatsapp"></i></a>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form">
          <h2>Send us a Message</h2>
          
          <% if (success) { %>
            <div class="success-message">
              <i class="fas fa-check-circle"></i>
              <p>Thank you! We'll get back to you soon.</p>
            </div>
          <% } %>

          <form action="/contact" method="POST">
            <div class="form-group">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone">
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-large">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map-section">
    <div class="container">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.7536224710217!2d32.5825!3d0.3136!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMMKwMTgnNDkuMCJOIDMywqAzNScwMC4wIkU!5e0!3m2!1sen!2sug!4v1620000000000!5m2!1sen!2sug"
        width="100%" 
        height="400" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy">
      </iframe>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3><%= config.business.name %></h3>
          <p><%= config.business.description %></p>
        </div>
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/repair">Repair</a></li>
            <li><a href="/sales">Phones</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Contact</h4>
          <p><i class="fas fa-phone"></i> <a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></p>
          <p><i class="fas fa-map-marker"></i> <%= config.contact.address %></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.business.name %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>