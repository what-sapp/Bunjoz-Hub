<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us - <%= config.business.name %></title>
  <meta name="description" content="Contact <%= config.business.owner %> at <%= config.business.name %>. Visit our shop on Kampala Road, call or WhatsApp us.">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/">
          <%= config.business.name %>
          <span>by <%= config.business.owner %></span>
        </a>
      </div>
      
      <div class="menu-toggle" id="menuToggle">
        <i class="fas fa-bars"></i>
      </div>
      
      <ul class="nav-links" id="navLinks">
        <li><a href="/">Home</a></li>
        <li><a href="/repair">Repair</a></li>
        <li><a href="/sales">Phones</a></li>
        <li><a href="/contact" class="active">Contact</a></li>
      </ul>
      
      <div class="phone-header">
        <a href="tel:<%= config.contact.phone %>">
          <i class="fas fa-phone-alt"></i> Call Now
        </a>
      </div>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-header" style="background: linear-gradient(135deg, var(--dark) 0%, #2d3748 100%);">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Get in touch with <%= config.business.owner %> - We're here to help!</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info-card">
          <h2>Visit Our Shop</h2>
          <p style="color: var(--gray); margin-bottom: 2rem;">Come say hi! <%= config.business.owner %> is usually at the shop and loves meeting customers.</p>
          
          <div class="info-item">
            <div class="info-icon">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <div class="info-content">
              <h3>Address</h3>
              <p><%= config.contact.address %></p>
              <p style="font-size: 0.9rem; margin-top: 0.5rem;">Landmark: Near the main taxi park</p>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-icon">
              <i class="fas fa-phone"></i>
            </div>
            <div class="info-content">
              <h3>Call or WhatsApp</h3>
              <p><a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></p>
              <p style="margin-top: 0.5rem;">
                <a href="<%= config.social.whatsapp %>" style="color: #25D366; text-decoration: none;">
                  <i class="fab fa-whatsapp"></i> Chat on WhatsApp
                </a>
              </p>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-icon">
              <i class="fas fa-envelope"></i>
            </div>
            <div class="info-content">
              <h3>Email</h3>
              <p><a href="mailto:<%= config.contact.email %>"><%= config.contact.email %></a></p>
              <p style="font-size: 0.9rem; margin-top: 0.5rem;">We reply within 24 hours</p>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-icon">
              <i class="fas fa-clock"></i>
            </div>
            <div class="info-content">
              <h3>Working Hours</h3>
              <p>Monday - Friday: <%= config.hours.monday_friday %></p>
              <p>Saturday: <%= config.hours.saturday %></p>
              <p>Sunday: <%= config.hours.sunday %></p>
            </div>
          </div>
          
          <div style="margin-top: 2rem;">
            <h3 style="margin-bottom: 1rem;">Follow Us</h3>
            <div class="social-links" style="justify-content: flex-start;">
              <a href="<%= config.social.facebook %>"><i class="fab fa-facebook-f"></i></a>
              <a href="<%= config.social.instagram %>"><i class="fab fa-instagram"></i></a>
              <a href="<%= config.social.twitter %>"><i class="fab fa-twitter"></i></a>
              <a href="<%= config.social.whatsapp %>"><i class="fab fa-whatsapp"></i></a>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="contact-form-card">
          <h2>Send a Message</h2>
          <p style="color: var(--gray); margin-bottom: 2rem;">Fill out the form and <%= config.business.owner %> will get back to you ASAP.</p>
          
          <% if (success) { %>
            <div class="success-message" style="background: #d1fae5; color: #065f46; padding: 1rem; border-radius: 10px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
              <i class="fas fa-check-circle" style="font-size: 1.5rem;"></i>
              <div>
                <strong>Message Sent!</strong>
                <p>Thank you for contacting <%= config.business.owner %>. We'll reply soon!</p>
              </div>
            </div>
          <% } %>

          <form action="/contact" method="POST">
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" required placeholder="Enter your full name">
            </div>
            
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="your@email.com">
            </div>
            
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="e.g., 0703 753787">
            </div>
            
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="general">General Inquiry</option>
                <option value="repair">Phone Repair</option>
                <option value="sales">Buying a Phone</option>
                <option value="other">Other</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="5" required placeholder="How can <%= config.business.owner %> help you?"></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary btn-large btn-block">
              <i class="fas fa-paper-plane"></i> Send Message
            </button>
          </form>
          
          <div style="margin-top: 2rem; text-align: center;">
            <p style="color: var(--gray); font-size: 0.9rem;">
              <i class="fas fa-clock"></i> Usually replies within 1 hour during business hours
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="map-section">
    <div class="container">
      <div class="map-container">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.7536224710217!2d32.5825!3d0.3136!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMMKwMTgnNDkuMCJOIDMywqAzNScwMC4wIkU!5e0!3m2!1sen!2sug!4v1620000000000!5m2!1sen!2sug"
          width="100%" 
          height="450" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy">
        </iframe>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
    <div class="container">
      <h2>Prefer to Talk Directly?</h2>
      <p>Call <%= config.business.owner %> now for immediate assistance</p>
      <div class="cta-buttons">
        <a href="tel:<%= config.contact.phone %>" class="btn btn-light btn-large">
          <i class="fas fa-phone"></i> <%= config.contact.phone_display %>
        </a>
        <a href="<%= config.social.whatsapp %>" class="btn btn-success btn-large">
          <i class="fab fa-whatsapp"></i> WhatsApp Now
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3><%= config.business.name %></h3>
          <p>Owned and operated by <%= config.business.owner %></p>
          <p><%= config.business.description %></p>
          <div class="social-links">
            <a href="<%= config.social.facebook %>"><i class="fab fa-facebook-f"></i></a>
            <a href="<%= config.social.instagram %>"><i class="fab fa-instagram"></i></a>
            <a href="<%= config.social.twitter %>"><i class="fab fa-twitter"></i></a>
            <a href="<%= config.social.whatsapp %>"><i class="fab fa-whatsapp"></i></a>
          </div>
        </div>
        
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/"><i class="fas fa-chevron-right"></i> Home</a></li>
            <li><a href="/repair"><i class="fas fa-chevron-right"></i> Repair Services</a></li>
            <li><a href="/sales"><i class="fas fa-chevron-right"></i> Phones for Sale</a></li>
            <li><a href="/contact"><i class="fas fa-chevron-right"></i> Contact Us</a></li>
          </ul>
        </div>
        
        <div class="footer-section">
          <h4>Contact Info</h4>
          <ul>
            <li><i class="fas fa-map-marker-alt"></i> <%= config.contact.address %></li>
            <li><i class="fas fa-phone"></i> <a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></li>
            <li><i class="fas fa-envelope"></i> <a href="mailto:<%= config.contact.email %>"><%= config.contact.email %></a></li>
            <li><i class="fas fa-clock"></i> Mon-Fri: <%= config.hours.monday_friday %></li>
          </ul>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.business.name %>. Created with <i class="fas fa-heart" style="color: #ef4444;"></i> by <%= config.business.owner %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>