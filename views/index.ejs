<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= config.business.name %> - <%= config.business.tagline %></title>
  <meta name="description" content="<%= config.business.description %>">
  <meta name="keywords" content="<%= config.seo.keywords %>">
  <meta name="author" content="<%= config.seo.author %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/">
          <%= config.business.name %>
          <span>by <%= config.business.owner %></span>
        </a>
      </div>
      
      <div class="menu-toggle" id="menuToggle">
        <i class="fas fa-bars"></i>
      </div>
      
      <ul class="nav-links" id="navLinks">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="/repair">Repair</a></li>
        <li><a href="/sales">Phones</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      
      <div class="phone-header">
        <a href="tel:<%= config.contact.phone %>">
          <i class="fas fa-phone-alt"></i> Call Now
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero Section with Video Background -->
  <section class="hero">
    <!-- Video Background (no sound) -->
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="https://files.catbox.moe/36k52y.mp4" type="video/mp4">
      <!-- Fallback if video doesn't load -->
      Your browser does not support the video tag.
    </video>
    
    <!-- Overlay to make text readable -->
    <div class="hero-overlay"></div>
    
    <div class="container">
      <div class="hero-content">
        <h1><%= config.business.tagline %></h1>
        <p><%= config.business.description %></p>
        <div class="hero-buttons">
          <a href="/repair" class="btn btn-light">
            <i class="fas fa-tools"></i> Repair Your Phone
          </a>
          <a href="/sales" class="btn btn-outline" style="border-color: white; color: white;">
            <i class="fas fa-mobile-alt"></i> Shop Phones
          </a>
        </div>
        <div class="owner-tag">
          <i class="fas fa-user"></i> Hi, I'm <%= config.business.owner %> - Let me help you with your phone!
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <% config.stats.forEach(stat => { %>
          <div class="stat-item">
            <div class="stat-icon">
              <i class="<%= stat.icon %>"></i>
            </div>
            <div class="stat-number"><%= stat.number %></div>
            <div class="stat-label"><%= stat.label %></div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Featured Phones -->
  <section class="featured-section">
    <div class="container">
      <h2 class="section-title">Featured Phones</h2>
      <p class="section-subtitle">Check out our latest arrivals - handpicked by <%= config.business.owner %></p>
      
      <div class="phones-grid">
        <% phones.forEach(phone => { %>
          <div class="phone-card">
            <div class="phone-image">
              <img src="<%= phone.image %>" alt="<%= phone.name %>" onerror="this.src='<%= config.images.default_phone %>'">
              <span class="condition-badge <%= phone.condition.toLowerCase() %>"><%= phone.condition %></span>
            </div>
            <div class="phone-info">
              <h3><%= phone.name %></h3>
              <div class="phone-specs">
                <span><i class="fas fa-microchip"></i> <%= phone.storage %></span>
                <span><i class="fas fa-memory"></i> <%= phone.ram %></span>
                <span><i class="fas fa-palette"></i> <%= phone.color %></span>
              </div>
              <div class="phone-price"><%= phone.price_formatted %></div>
              <a href="/phone/<%= phone.id %>" class="btn btn-primary btn-block">View Details</a>
            </div>
          </div>
        <% }); %>
      </div>
      
      <div class="text-center mt-3">
        <a href="/sales" class="btn btn-outline btn-large">
          View All Phones <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="services-section">
    <div class="container">
      <h2 class="section-title">Our Services</h2>
      <p class="section-subtitle">Professional repairs by expert technicians</p>
      
      <div class="services-grid">
        <% config.services.slice(0, 3).forEach(service => { %>
          <div class="service-card">
            <div class="service-icon">
              <i class="<%= service.icon %>"></i>
            </div>
            <h3><%= service.name %></h3>
            <p><%= service.description %></p>
            <div class="service-features">
              <% service.features.slice(0, 2).forEach(feature => { %>
                <span><i class="fas fa-check"></i> <%= feature %></span>
              <% }); %>
            </div>
            <a href="/repair" class="service-btn">
              Learn More <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        <% }); %>
      </div>
      
      <div class="text-center mt-3">
        <a href="/repair" class="btn btn-primary btn-large">
          View All Services <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features-section">
    <div class="container">
      <h2 class="section-title">Why Choose <%= config.business.name %>?</h2>
      <p class="section-subtitle">We put our customers first, always</p>
      
      <div class="features-grid">
        <% config.features.forEach(feature => { %>
          <div class="feature-card">
            <div class="feature-icon">
              <i class="<%= feature.icon %>"></i>
            </div>
            <h3><%= feature.title %></h3>
            <p><%= feature.description %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Brands Section -->
  <section class="brands-section">
    <div class="container">
      <h2 class="section-title">Brands We Work With</h2>
      <p class="section-subtitle">All major brands supported</p>
      
      <div class="brands-grid">
        <% config.brands.forEach(brand => { %>
          <div class="brand-item">
            <i class="<%= brand.icon %>"></i>
            <span><%= brand.name %></span>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2 class="section-title">What Our Customers Say</h2>
      <p class="section-subtitle">Don't just take our word for it</p>
      
      <div class="testimonials-grid">
        <% config.testimonials.forEach(testimonial => { %>
          <div class="testimonial-card">
            <div class="testimonial-rating">
              <% for(let i = 0; i < testimonial.rating; i++) { %>
                <i class="fas fa-star"></i>
              <% } %>
            </div>
            <p class="testimonial-comment">"<%= testimonial.comment %>"</p>
            <div class="testimonial-author">- <%= testimonial.name %></div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>Need a Repair or Looking for a Phone?</h2>
      <p>Visit our shop today or give us a call - <%= config.business.owner %> will personally assist you!</p>
      <div class="cta-buttons">
        <a href="tel:<%= config.contact.phone %>" class="btn btn-light btn-large">
          <i class="fas fa-phone"></i> Call Now
        </a>
        <a href="<%= config.social.whatsapp %>" class="btn btn-success btn-large">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
        <a href="/contact" class="btn btn-outline btn-large" style="border-color: white; color: white;">
          <i class="fas fa-envelope"></i> Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3><%= config.business.name %></h3>
          <p>Owned and operated by <%= config.business.owner %></p>
          <p><%= config.business.description %></p>
          <div class="social-links">
            <a href="<%= config.social.facebook %>"><i class="fab fa-facebook-f"></i></a>
            <a href="<%= config.social.instagram %>"><i class="fab fa-instagram"></i></a>
            <a href="<%= config.social.twitter %>"><i class="fab fa-twitter"></i></a>
            <a href="<%= config.social.whatsapp %>"><i class="fab fa-whatsapp"></i></a>
          </div>
        </div>
        
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/"><i class="fas fa-chevron-right"></i> Home</a></li>
            <li><a href="/repair"><i class="fas fa-chevron-right"></i> Repair Services</a></li>
            <li><a href="/sales"><i class="fas fa-chevron-right"></i> Phones for Sale</a></li>
            <li><a href="/contact"><i class="fas fa-chevron-right"></i> Contact Us</a></li>
          </ul>
        </div>
        
        <div class="footer-section">
          <h4>Contact Info</h4>
          <ul>
            <li><i class="fas fa-map-marker-alt"></i> <%= config.contact.address %></li>
            <li><i class="fas fa-phone"></i> <a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></li>
            <li><i class="fas fa-envelope"></i> <a href="mailto:<%= config.contact.email %>"><%= config.contact.email %></a></li>
            <li><i class="fas fa-clock"></i> Mon-Fri: <%= config.hours.monday_friday %></li>
          </ul>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.business.name %>. Created with <i class="fas fa-heart" style="color: #ef4444;"></i> by <%= config.business.owner %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>