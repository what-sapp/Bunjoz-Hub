<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= config.business.name %> - <%= config.business.tagline %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/"><%= config.business.name %></a>
      </div>
      <ul class="nav-links">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="/repair">Repair</a></li>
        <li><a href="/sales">Phones</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="phone-header">
        <a href="tel:<%= config.contact.phone %>"><i class="fas fa-phone"></i> <%= config.contact.phone_display %></a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1><%= config.business.tagline %></h1>
        <p><%= config.business.description %></p>
        <div class="hero-buttons">
          <a href="/repair" class="btn btn-primary">Repair Your Phone</a>
          <a href="/sales" class="btn btn-secondary">Shop Phones</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Phones -->
  <section class="featured">
    <div class="container">
      <h2 class="section-title">Featured Phones</h2>
      <div class="phones-grid">
        <% phones.forEach(phone => { %>
          <div class="phone-card">
            <img src="<%= phone.image %>" alt="<%= phone.name %>" onerror="this.src='<%= config.images.default_phone %>'">
            <div class="phone-info">
              <h3><%= phone.name %></h3>
              <div class="phone-specs">
                <span><i class="fas fa-microchip"></i> <%= phone.storage %></span>
                <span><i class="fas fa-memory"></i> <%= phone.ram %></span>
              </div>
              <div class="phone-price"><%= phone.price_formatted %></div>
              <a href="/phone/<%= phone.id %>" class="btn btn-small">View Details</a>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="view-all">
        <a href="/sales" class="btn btn-outline">View All Phones →</a>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="services-preview">
    <div class="container">
      <h2 class="section-title">Our Services</h2>
      <div class="services-grid-small">
        <% config.services.slice(0, 4).forEach(service => { %>
          <div class="service-item">
            <i class="<%= service.icon %>"></i>
            <h3><%= service.name %></h3>
          </div>
        <% }); %>
      </div>
      <div class="view-all">
        <a href="/repair" class="btn btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="why-us">
    <div class="container">
      <h2 class="section-title">Why Choose Us?</h2>
      <div class="features-grid">
        <% config.features.slice(0, 4).forEach(feature => { %>
          <div class="feature">
            <i class="fas fa-check-circle"></i>
            <span><%= feature %></span>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2>Need Help?</h2>
      <p>Call us or visit our shop today</p>
      <a href="tel:<%= config.contact.phone %>" class="btn btn-primary btn-large">
        <i class="fas fa-phone"></i> <%= config.contact.phone_display %>
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3><%= config.business.name %></h3>
          <p><%= config.business.description %></p>
        </div>
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/repair">Repair</a></li>
            <li><a href="/sales">Phones</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Contact</h4>
          <p><i class="fas fa-phone"></i> <a href="tel:<%= config.contact.phone %>"><%= config.contact.phone_display %></a></p>
          <p><i class="fas fa-map-marker"></i> <%= config.contact.address %></p>
          <p><i class="fas fa-clock"></i> Mon-Sat: <%= config.hours.monday_friday %></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= config.business.name %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>